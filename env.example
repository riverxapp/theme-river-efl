# OpenAI defaults
OPENAI_API_KEY=your-openai-api-key
# Optional; falls back to this model when unset in runtime code
OPENAI_MODEL=gpt-4o-mini

# Database (PostgreSQL on Railway example)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL="postgresql://postgres:password@hostname:5432/railway"
DATABASE_SSL=false

# Canonical app URL for app links and callbacks
BASE_URL="http://localhost:3000"

# SendGrid (used for team invitations and transactional email)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# Optional: Auth.js / NextAuth secret (only needed if/when NextAuth session routes are added)
NEXTAUTH_SECRET=${AUTH_SECRET}
